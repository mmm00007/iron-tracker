    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-query-persist-client": "^5.59.20",
    "@tanstack/react-router": "^1.79.0",
    "idb-keyval": "^6.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
